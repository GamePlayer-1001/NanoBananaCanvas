# ============================================
# Nano Banana Canvas — 环境变量模板
# 复制为 .env.local 后填入真实值
# ============================================
# 当前: Development / Test Mode
# Stripe 和 Clerk 使用测试密钥，域名已上线
# 迁移到 Production 请参考 .md/生产环境迁移清单.md

# ── 应用 ─────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Nano Banana Canvas
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Clerk 认证 ───────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Stripe 支付 ──────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_CONFIGURATION_ID=
STRIPE_DEFAULT_CURRENCY=usd

# Stripe 价格 ID（四档套餐 + 积分包，多币种）
# 命名规则：
# 1. 如果一个 Stripe Price 内部已经配置了多币种，请优先只填共享 Price ID：
#    STRIPE_PRICE_<PLAN>_PLAN_AUTO_MONTHLY
#    STRIPE_PRICE_<PLAN>_PLAN_ONE_TIME
#    STRIPE_PRICE_CREDIT_PACK_<PACK>
# 2. 只有当你真的为不同币种拆成不同 Price 时，才额外填写 *_<CURRENCY>
# 3. PLAN 取值：STANDARD / PRO / ULTIMATE
# 4. PACK 取值：500 / 1200 / 3500 / 8000
# 5. CURRENCY 取值：USD / EUR / GBP / CNY
STRIPE_PRICE_STANDARD_PLAN_AUTO_MONTHLY=
STRIPE_PRICE_STANDARD_PLAN_ONE_TIME=
STRIPE_PRICE_PRO_PLAN_AUTO_MONTHLY=
STRIPE_PRICE_PRO_PLAN_ONE_TIME=
STRIPE_PRICE_ULTIMATE_PLAN_AUTO_MONTHLY=
STRIPE_PRICE_ULTIMATE_PLAN_ONE_TIME=
STRIPE_PRICE_CREDIT_PACK_500=
STRIPE_PRICE_CREDIT_PACK_1200=
STRIPE_PRICE_CREDIT_PACK_3500=
STRIPE_PRICE_CREDIT_PACK_8000=

# 可选：仅当不同币种对应不同 Stripe Price ID 时再填写
STRIPE_PRICE_STANDARD_PLAN_AUTO_MONTHLY_USD=
STRIPE_PRICE_STANDARD_PLAN_AUTO_MONTHLY_EUR=
STRIPE_PRICE_STANDARD_PLAN_AUTO_MONTHLY_GBP=
STRIPE_PRICE_STANDARD_PLAN_AUTO_MONTHLY_CNY=
STRIPE_PRICE_STANDARD_PLAN_ONE_TIME_USD=
STRIPE_PRICE_STANDARD_PLAN_ONE_TIME_EUR=
STRIPE_PRICE_STANDARD_PLAN_ONE_TIME_GBP=
STRIPE_PRICE_STANDARD_PLAN_ONE_TIME_CNY=
STRIPE_PRICE_PRO_PLAN_AUTO_MONTHLY_USD=
STRIPE_PRICE_PRO_PLAN_AUTO_MONTHLY_EUR=
STRIPE_PRICE_PRO_PLAN_AUTO_MONTHLY_GBP=
STRIPE_PRICE_PRO_PLAN_AUTO_MONTHLY_CNY=
STRIPE_PRICE_PRO_PLAN_ONE_TIME_USD=
STRIPE_PRICE_PRO_PLAN_ONE_TIME_EUR=
STRIPE_PRICE_PRO_PLAN_ONE_TIME_GBP=
STRIPE_PRICE_PRO_PLAN_ONE_TIME_CNY=
STRIPE_PRICE_ULTIMATE_PLAN_AUTO_MONTHLY_USD=
STRIPE_PRICE_ULTIMATE_PLAN_AUTO_MONTHLY_EUR=
STRIPE_PRICE_ULTIMATE_PLAN_AUTO_MONTHLY_GBP=
STRIPE_PRICE_ULTIMATE_PLAN_AUTO_MONTHLY_CNY=
STRIPE_PRICE_ULTIMATE_PLAN_ONE_TIME_USD=
STRIPE_PRICE_ULTIMATE_PLAN_ONE_TIME_EUR=
STRIPE_PRICE_ULTIMATE_PLAN_ONE_TIME_GBP=
STRIPE_PRICE_ULTIMATE_PLAN_ONE_TIME_CNY=
STRIPE_PRICE_CREDIT_PACK_500_USD=
STRIPE_PRICE_CREDIT_PACK_500_EUR=
STRIPE_PRICE_CREDIT_PACK_500_GBP=
STRIPE_PRICE_CREDIT_PACK_500_CNY=
STRIPE_PRICE_CREDIT_PACK_1200_USD=
STRIPE_PRICE_CREDIT_PACK_1200_EUR=
STRIPE_PRICE_CREDIT_PACK_1200_GBP=
STRIPE_PRICE_CREDIT_PACK_1200_CNY=
STRIPE_PRICE_CREDIT_PACK_3500_USD=
STRIPE_PRICE_CREDIT_PACK_3500_EUR=
STRIPE_PRICE_CREDIT_PACK_3500_GBP=
STRIPE_PRICE_CREDIT_PACK_3500_CNY=
STRIPE_PRICE_CREDIT_PACK_8000_USD=
STRIPE_PRICE_CREDIT_PACK_8000_EUR=
STRIPE_PRICE_CREDIT_PACK_8000_GBP=
STRIPE_PRICE_CREDIT_PACK_8000_CNY=

# ── AI 服务 ──────────────────────────────────
OPENROUTER_API_KEY=

# ── 安全 ─────────────────────────────────────
# 32 字节 hex 密钥，用于 AES-256-GCM 加密用户 API Key
# 生成: openssl rand -hex 32
ENCRYPTION_KEY=
