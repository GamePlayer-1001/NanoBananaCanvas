# ============================================
# Nano Banana Canvas — 环境变量模板
# 复制为 .env.local 后填入真实值
# ============================================
# 当前: Development / Test Mode
# Stripe 和 Clerk 使用测试密钥，域名已上线
# 迁移到 Production 请参考 .md/生产环境迁移清单.md

# ── 应用 ─────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Nano Banana Canvas
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Clerk 认证 ───────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Stripe 支付 ──────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe 订阅套餐价格 ID (Stripe Dashboard 创建后填入)
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_STANDARD_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ULTIMATE_MONTHLY=
STRIPE_PRICE_ULTIMATE_YEARLY=

# ── AI 服务 ──────────────────────────────────
OPENROUTER_API_KEY=

# ── 安全 ─────────────────────────────────────
# 32 字节 hex 密钥，用于 AES-256-GCM 加密用户 API Key
# 生成: openssl rand -hex 32
ENCRYPTION_KEY=