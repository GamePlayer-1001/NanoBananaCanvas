{
  "name": "@nano-banana/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:e2e": "next dev --turbopack --port 3000",
    "build": "pnpm run clean && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "i18n:index": "node ./scripts/i18n-tools.mjs generate",
    "i18n:validate": "node ./scripts/i18n-tools.mjs validate",
    "i18n:sync": "node ./scripts/i18n-tools.mjs sync",
    "i18n:add-locale": "node ./scripts/i18n-tools.mjs add-locale",
    "i18n:check": "node ./scripts/i18n-tools.mjs check",
    "deploy:build": "node ./scripts/cloudflare-deploy.mjs build",
    "deploy:preview": "npx opennextjs-cloudflare preview",
    "deploy": "node ./scripts/cloudflare-deploy.mjs deploy",
    "dev:cf": "npx wrangler dev --compatibility-date=2025-04-01 --compatibility-flags=nodejs_compat --d1=DB",
    "db:init": "npx wrangler d1 execute nano-banana-canvas-db --local --file=./db/schema.sql",
    "db:seed": "npx wrangler d1 execute nano-banana-canvas-db --local --file=./db/seed.sql",
    "db:seed-models": "npx wrangler d1 execute nano-banana-canvas-db --local --file=./db/seed-models.sql",
    "clean": "node -e \"const fs=require('fs'); for (const target of ['.next','.turbo']) fs.rmSync(target,{recursive:true,force:true}); fs.rmSync('tsconfig.tsbuildinfo',{force:true});\""
  },
  "dependencies": {
    "@clerk/localizations": "^4.5.2",
    "@clerk/nextjs": "^7.2.3",
    "@hookform/resolvers": "^5.2.2",
    "@nano-banana/shared": "workspace:*",
    "@opennextjs/cloudflare": "^1.17.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
